---
import { getEntry } from 'astro:content';
import { ClientRouter } from 'astro:transitions';
import '../styles/global.css';
import Preloader from '../components/Preloader.astro';
import Navbar from '../components/Navbar.astro';
import Cursor from '../components/Cursor.astro';
import Footer from '../components/Footer.astro';
import ChatWidget from '../components/ChatWidget.astro';

interface Props {
  title?: string;
  description?: string;
  noindex?: boolean;
}

const settingsEntry = await getEntry('settings', 'settings');
const settings = settingsEntry!.data;

const { title = settings.titreSEO, description = settings.metaDescription, noindex = false } = Astro.props;

const canonicalURL = new URL(Astro.url.pathname, Astro.site);
// `|| ` plutôt que `?? ` : une chaîne vide (champ vidé depuis l'admin)
// doit retomber sur l'image par défaut, pas résoudre une URL vide.
const ogImageURL = new URL(settings.imageOG || '/og.jpg', Astro.site);

// Le balisage Person n'a de sens que sur les pages qui parlent de Germain
// lui-même — pas sur une fiche projet ou le formulaire de contact.
const includePersonSchema = ['/', '/a-propos'].includes(Astro.url.pathname);

const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'Person',
  name: settings.nomComplet,
  jobTitle: 'Développeur Fullstack & Fondateur EdTech',
  url: Astro.site?.toString(),
  address: {
    '@type': 'PostalAddress',
    addressLocality: 'Conakry',
    addressCountry: 'GN',
  },
  sameAs: settings.reseaux.map((r) => r.url),
};
---

<!doctype html>
<html lang="fr">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="canonical" href={canonicalURL} />
    <meta name="generator" content={Astro.generator} />

    <title>{title}</title>
    <meta name="description" content={description} />
    {noindex && <meta name="robots" content="noindex, nofollow" />}

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={ogImageURL} />
    <meta property="og:locale" content="fr_FR" />

    <!-- Twitter -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImageURL} />

    {includePersonSchema && <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />}

    <ClientRouter />

    <noscript>
      <style>
        [data-hero] {
          visibility: visible !important;
        }
        [data-hero-hex-glow] {
          opacity: 1 !important;
        }
        [data-preloader] {
          display: none !important;
        }
      </style>
    </noscript>
  </head>
  <body>
    <div class="hex-grid-bg" aria-hidden="true"></div>
    <Preloader />
    <Navbar />
    <Cursor />
    <main>
      <slot />
    </main>
    <Footer />
    <ChatWidget />

    <script>
      import { initPageLifecycle } from '../scripts/bootstrap';
      initPageLifecycle();
    </script>
  </body>
</html>
