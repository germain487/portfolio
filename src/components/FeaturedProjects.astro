---
import { getCollection, getEntry } from 'astro:content';
import ProjectCard from './ProjectCard.astro';
import StyledText from './StyledText.astro';

const allProjects = await getCollection('projets', ({ data }) => !data.brouillon && data.misEnAvant);
const projects = allProjects.sort((a, b) => a.data.ordre - b.data.ordre).slice(0, 3);

const sectionsEntry = await getEntry('sections', 'sections');
const sections = sectionsEntry!.data;
---

<section class="reveal-section py-16 md:py-20">
  <div class="mx-auto max-w-6xl px-6">
    <div class="flex flex-wrap items-end justify-between gap-6">
      <div>
        <p class="font-mono text-xs uppercase tracking-[0.12em] text-accent">// projets</p>
        <StyledText
          as="h2"
          alignement={sections.projetsTitre.alignement}
          police={sections.projetsTitre.police}
          taille={sections.projetsTitre.taille}
          class="mt-4 max-w-2xl font-bold leading-tight text-text"
        >
          {sections.projetsTitre.texte}
        </StyledText>
      </div>
      <a
        href="/projets"
        class="inline-flex shrink-0 items-center gap-2 font-mono text-sm text-accent transition-transform duration-300 hover:translate-x-1"
      >
        Voir tous les projets →
      </a>
    </div>

    <div class="mt-10 grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
      {projects.map((project) => (
        <ProjectCard
          slug={project.id}
          titre={project.data.titre}
          description={project.data.description}
          stack={project.data.stack}
          tags={project.data.tags}
          annee={project.data.annee}
          statut={project.data.statut}
          couverture={project.data.couverture}
        />
      ))}
    </div>
  </div>
</section>
