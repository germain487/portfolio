---
import { getEntry } from 'astro:content';
import Icon from './Icon.astro';
import HexPortrait from './HexPortrait.astro';
import MagneticButton from './MagneticButton.astro';

const settingsEntry = await getEntry('settings', 'settings');
const heroEntry = await getEntry('hero', 'hero');
const settings = settingsEntry!.data;
const hero = heroEntry!.data;

const socialIconMap: Record<string, string> = {
  LinkedIn: 'linkedin',
  GitHub: 'github',
  X: 'twitter',
  Facebook: 'facebook',
};
---

<section
  id="accueil"
  data-hero
  data-roles={JSON.stringify(hero.roles)}
  class="hero relative overflow-hidden pt-40 pb-24 md:pt-48 md:pb-32"
  style="visibility:hidden;"
>
  <div class="mx-auto grid max-w-6xl items-center gap-16 px-6 md:grid-cols-2">
    <div class="order-2 md:order-1">
      <p data-hero-eyebrow class="font-mono text-xs uppercase tracking-[0.12em] text-accent">
        {hero.eyebrow}
      </p>

      <h1
        data-hero-name
        class="mt-4 font-display text-[clamp(2.5rem,6vw,4.5rem)] font-bold leading-[1.05] text-text"
      >
        {settings.nomComplet}
      </h1>

      <p
        data-hero-role
        class="mt-4 flex items-center gap-1 font-display text-xl font-medium text-accent md:text-2xl"
      >
        <span aria-hidden="true" data-typewriter>{hero.roles[0]}</span>
        <span aria-hidden="true" class="typewriter-cursor">|</span>
        <span class="sr-only">{hero.roles.join(' · ')}</span>
      </p>

      <p data-hero-tagline class="mt-6 max-w-md text-base leading-[1.7] text-text-muted">
        {hero.accroche}
      </p>

      {settings.disponible && (
        <div class="mt-6 inline-flex items-center gap-2 rounded-pill border border-surface-2 px-4 py-2 font-mono text-xs text-text-muted">
          <span class="relative flex h-2 w-2">
            <span class="absolute inline-flex h-full w-full animate-ping rounded-full bg-emerald-400 opacity-75"></span>
            <span class="relative inline-flex h-2 w-2 rounded-full bg-emerald-400"></span>
          </span>
          {settings.badgeTexte}
        </div>
      )}

      <div data-hero-cta class="mt-8 flex flex-wrap items-center gap-4">
        <MagneticButton href={settings.cv} download variant="primary">
          <Icon name="download" size={16} />
          {hero.ctaPrimaireLabel}
        </MagneticButton>
        <MagneticButton href="#projets" variant="secondary">
          {hero.ctaSecondaireLabel}
        </MagneticButton>
      </div>

      <div class="mt-10 flex items-center gap-3">
        {settings.reseaux.map((reseau) => (
          <a
            href={reseau.url}
            target="_blank"
            rel="noopener noreferrer"
            aria-label={reseau.plateforme}
            class="grid h-10 w-10 place-items-center rounded-full border border-surface-2 text-text-muted transition-all duration-300 hover:border-accent hover:bg-accent hover:text-bg hover:shadow-[0_0_24px_rgba(0,229,255,0.35)]"
          >
            <Icon name={socialIconMap[reseau.plateforme] ?? 'globe'} size={17} />
          </a>
        ))}
      </div>
    </div>

    <div class="order-1 md:order-2" data-hero-hex-glow style="opacity:0;">
      <HexPortrait src={hero.portrait} alt={`Portrait de ${settings.nomComplet}`} />
    </div>
  </div>
</section>

<script>
  import { initTypewriter, initHeroIntro, initPortraitTilt } from '../scripts/motion';

  const heroSection = document.querySelector('[data-hero]');
  const typewriterEl = document.querySelector<HTMLElement>('[data-typewriter]');
  const roles = JSON.parse(heroSection?.getAttribute('data-roles') ?? '[]');

  if (typewriterEl && roles.length) initTypewriter(typewriterEl, roles);

  initHeroIntro();
  initPortraitTilt();
</script>

<style>
  .typewriter-cursor {
    animation: blink 1s steps(1) infinite;
    color: var(--accent);
  }
  @keyframes blink {
    50% {
      opacity: 0;
    }
  }
</style>
