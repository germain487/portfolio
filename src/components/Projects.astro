---
import { getCollection, getEntry } from 'astro:content';
import ProjectCard from './ProjectCard.astro';
import StyledText from './StyledText.astro';

const allProjects = await getCollection('projets', ({ data }) => !data.brouillon);
const projects = allProjects.sort((a, b) => a.data.ordre - b.data.ordre);

const sectionsEntry = await getEntry('sections', 'sections');
const sections = sectionsEntry!.data;

const filters = ['Tous', 'SaaS', 'Civic Tech', 'Data', 'Web Design'];
---

<section id="projets" class="reveal-section py-16 md:py-20">
  <div class="mx-auto max-w-6xl px-6">
    <p class="font-mono text-xs uppercase tracking-[0.12em] text-accent">// projets</p>
    <StyledText
      as="h1"
      alignement={sections.projetsTitre.alignement}
      police={sections.projetsTitre.police}
      taille={sections.projetsTitre.taille}
      class="mt-4 max-w-2xl font-bold leading-tight text-text"
    >
      {sections.projetsTitre.texte}
    </StyledText>

    <div class="mt-10 flex flex-wrap gap-3">
      {filters.map((filter, i) => (
        <button
          type="button"
          data-filter={filter}
          class:list={[
            'filter-chip rounded-pill border px-4 py-2 font-mono text-xs uppercase tracking-wide transition-colors duration-300',
            i === 0 && 'is-active',
          ]}
        >
          {filter}
        </button>
      ))}
    </div>

    <div data-projects-grid class="mt-10 grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
      {projects.map((project) => (
        <ProjectCard
          slug={project.id}
          titre={project.data.titre}
          description={project.data.description}
          stack={project.data.stack}
          tags={project.data.tags}
          annee={project.data.annee}
          statut={project.data.statut}
          couverture={project.data.couverture}
        />
      ))}
    </div>
  </div>
</section>

<!-- Les filtres et le tilt des cartes sont (ré)initialisés de façon
     centralisée par scripts/bootstrap.ts sur `astro:page-load`, pas ici :
     voir Base.astro. -->

<style>
  .filter-chip {
    border-color: var(--surface-2);
    color: var(--text-muted);
  }
  .filter-chip.is-active,
  .filter-chip:hover {
    border-color: var(--accent);
    color: var(--accent);
  }
</style>
