---
import { getCollection } from 'astro:content';
import ProjectCard from './ProjectCard.astro';

const allProjects = await getCollection('projets', ({ data }) => !data.brouillon);
const projects = allProjects.sort((a, b) => a.data.ordre - b.data.ordre);

const filters = ['Tous', 'SaaS', 'Civic Tech', 'Data', 'Web Design'];
---

<section id="projets" class="reveal-section py-24 md:py-32">
  <div class="mx-auto max-w-6xl px-6">
    <p class="font-mono text-xs uppercase tracking-[0.12em] text-accent">// projets</p>
    <h2 class="mt-4 max-w-2xl font-display text-[clamp(1.75rem,4vw,2.75rem)] font-bold leading-tight text-text">
      Des produits qui tournent en production, pas des maquettes.
    </h2>

    <div class="mt-10 flex flex-wrap gap-3">
      {filters.map((filter, i) => (
        <button
          type="button"
          data-filter={filter}
          class:list={[
            'filter-chip rounded-pill border px-4 py-2 font-mono text-xs uppercase tracking-wide transition-colors duration-300',
            i === 0 && 'is-active',
          ]}
        >
          {filter}
        </button>
      ))}
    </div>

    <div data-projects-grid class="mt-10 grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
      {projects.map((project) => (
        <ProjectCard
          slug={project.id}
          titre={project.data.titre}
          description={project.data.description}
          stack={project.data.stack}
          tags={project.data.tags}
          annee={project.data.annee}
          statut={project.data.statut}
          lien={project.data.lien}
          couverture={project.data.couverture}
        />
      ))}
    </div>
  </div>
</section>

<script>
  import { initProjectFilters, initCardTilt } from '../scripts/motion';
  initProjectFilters();
  initCardTilt('[data-project-tilt]', 6);
</script>

<style>
  .filter-chip {
    border-color: var(--surface-2);
    color: var(--text-muted);
  }
  .filter-chip.is-active,
  .filter-chip:hover {
    border-color: var(--accent);
    color: var(--accent);
  }
</style>
