---
import { getEntry } from 'astro:content';
import MagneticButton from './MagneticButton.astro';
import Icon from './Icon.astro';

const settingsEntry = await getEntry('settings', 'settings');
const settings = settingsEntry!.data;
---

<section class="reveal-section py-24 md:py-32">
  <div class="mx-auto max-w-6xl px-6">
    <div class="rounded-container border border-surface-2 bg-surface px-8 py-16 text-center md:px-16">
      <p class="font-mono text-xs uppercase tracking-[0.12em] text-accent">// contact</p>
      <h2 class="mx-auto mt-4 max-w-xl font-display text-[clamp(1.75rem,4vw,2.75rem)] font-bold leading-tight text-text">
        Un projet, une question ?
      </h2>
      <p class="mx-auto mt-4 max-w-md text-base leading-[1.7] text-text-muted">
        Écrivez-moi — je réponds sous 24 h.
      </p>
      <div class="mt-8 flex justify-center">
        <MagneticButton href="/contact" variant="primary">
          <Icon name="send" size={16} />
          Discutons de votre projet
        </MagneticButton>
      </div>
      <p class="mt-4 font-mono text-xs text-text-muted">{settings.email}</p>
    </div>
  </div>
</section>
