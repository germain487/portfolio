---
import { getEntry } from 'astro:content';
import Icon from './Icon.astro';

const servicesEntry = await getEntry('services', 'services');
const services = servicesEntry!.data;
---

<section class="reveal-section py-16 md:py-24">
  <div class="mx-auto max-w-6xl px-6">
    <div class="flex flex-wrap items-end justify-between gap-6">
      <div>
        <p class="font-mono text-xs uppercase tracking-[0.12em] text-accent">// services</p>
        <h2 class="mt-4 max-w-2xl font-display text-[clamp(1.75rem,4vw,2.75rem)] font-bold leading-tight text-text">
          Au-delà du code, un partenaire technique.
        </h2>
      </div>
      <a
        href="/services"
        class="inline-flex shrink-0 items-center gap-2 font-mono text-sm text-accent transition-transform duration-300 hover:translate-x-1"
      >
        Voir tous les services →
      </a>
    </div>

    <div class="mt-10 grid gap-6 sm:grid-cols-2 lg:grid-cols-4">
      {services.cartes.map((carte) => (
        <div class="rounded-card border border-surface-2 bg-surface p-7">
          <div class="grid h-11 w-11 place-items-center rounded-full border border-surface-2 text-accent">
            <Icon name={carte.icone} size={20} />
          </div>
          <h3 class="mt-5 font-display text-base font-medium leading-snug text-text">{carte.titre}</h3>
          <p class="mt-3 text-sm leading-relaxed text-text-muted">{carte.phrase}</p>
        </div>
      ))}
    </div>
  </div>
</section>
