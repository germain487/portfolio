---
import { getEntry } from 'astro:content';
import Icon from './Icon.astro';
import StyledText from './StyledText.astro';

const servicesEntry = await getEntry('services', 'services');
const sectionsEntry = await getEntry('sections', 'sections');
const services = servicesEntry!.data;
const sections = sectionsEntry!.data;
---

<section id="services" class="reveal-section py-16 md:py-20">
  <div class="mx-auto max-w-6xl px-6">
    <p class="font-mono text-xs uppercase tracking-[0.12em] text-accent">// services</p>
    <StyledText
      as="h1"
      alignement={sections.servicesTitre.alignement}
      police={sections.servicesTitre.police}
      taille={sections.servicesTitre.taille}
      class="mt-4 max-w-2xl font-bold leading-tight text-text"
    >
      {sections.servicesTitre.texte}
    </StyledText>

    <div class="mt-14 grid gap-6 sm:grid-cols-2 lg:grid-cols-4">
      {services.cartes.map((carte) => (
        <div class="rounded-card border border-surface-2 bg-surface p-7">
          <div class="grid h-11 w-11 place-items-center rounded-full border border-surface-2 text-accent">
            <Icon name={carte.icone} size={20} />
          </div>
          <StyledText
            as="h3"
            alignement={carte.titre.alignement}
            police={carte.titre.police}
            taille={carte.titre.taille}
            class="mt-5 font-medium leading-snug text-text"
          >
            {carte.titre.texte}
          </StyledText>
          <StyledText
            as="p"
            alignement={carte.phrase.alignement}
            police={carte.phrase.police}
            taille={carte.phrase.taille}
            class="mt-3 leading-relaxed text-text-muted"
          >
            {carte.phrase.texte}
          </StyledText>
        </div>
      ))}
    </div>

    <div class="mt-14 text-center">
      <a
        href="/contact"
        class="inline-flex items-center gap-2 font-mono text-sm text-accent transition-transform duration-300 hover:translate-x-1"
      >
        {services.ctaFinalLabel}
      </a>
    </div>
  </div>
</section>
