---
import { getEntry } from 'astro:content';

const aboutEntry = await getEntry('about', 'about');
const about = aboutEntry!.data;

const renderBold = (text: string) =>
  text.replace(/\*\*(.+?)\*\*/g, '<strong class="font-medium text-text">$1</strong>');
---

<section class="reveal-section py-16 md:py-24">
  <div class="mx-auto max-w-6xl px-6">
    <p class="font-mono text-xs uppercase tracking-[0.12em] text-accent">// à-propos</p>
    <h2 class="mt-4 max-w-2xl font-display text-[clamp(1.75rem,4vw,2.75rem)] font-bold leading-tight text-text">
      {about.titre}
    </h2>

    <p
      class="mt-8 line-clamp-3 max-w-2xl text-base leading-[1.7] text-text-muted"
      set:html={renderBold(about.paragraphes[0])}
    />

    <a
      href="/a-propos"
      class="mt-6 inline-flex items-center gap-2 font-mono text-sm text-accent transition-transform duration-300 hover:translate-x-1"
    >
      En savoir plus →
    </a>
  </div>
</section>
