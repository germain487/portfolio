---
// Bulle + panneau de Louise, persistants entre les pages (transition:persist,
// comme la navbar et le curseur). Le HTML est statique et léger — la logique
// (ouverture, envoi de messages, appel de la fonction Netlify) ne se charge
// qu'à la première ouverture, via import dynamique dans scripts/motion.ts
// (voir initChatWidget), pour ne rien ajouter au JS initial du site.
import { getEntry } from 'astro:content';
import Icon from './Icon.astro';

const chatbotEntry = await getEntry('chatbot', 'chatbot');
const chatbot = chatbotEntry?.data;
---

{
  chatbot?.actif && (
    <div
      data-chat-widget
      data-chat-greeting={chatbot.messageAccueil}
      data-chat-offline="Louise est indisponible pour le moment. Écrivez directement à Germain sur WhatsApp ou via la page Contact."
      data-chat-animation={chatbot.animationAttention}
      transition:persist="chat-widget"
    >
      {chatbot.animationAttention === 'heartbeat_radar' && (
        <span data-chat-radar aria-hidden="true" class="chat-radar fixed bottom-6 right-6 z-30 h-14 w-14" />
      )}

      <button
        type="button"
        data-chat-toggle
        aria-haspopup="dialog"
        aria-expanded="false"
        aria-controls="louise-panel"
        aria-label="Ouvrir le chat avec Louise, assistante du site"
        title="Ouvrir le chat avec Louise, assistante du site"
        class="chat-bubble fixed bottom-6 right-6 z-40 grid h-14 w-14 place-items-center text-bg"
      >
        <span data-chat-icon-open class="grid place-items-center font-display text-xl font-bold">L</span>
        <span data-chat-icon-close class="hidden place-items-center">
          <Icon name="x" size={20} />
        </span>
      </button>

      {chatbot.badgeInvitationActif && (
        <div
          data-chat-badge
          aria-hidden="true"
          hidden
          class="chat-badge fixed bottom-24 right-6 z-40 max-w-[14rem] rounded-card border border-surface-2 bg-surface px-4 py-2.5 text-sm text-text"
        >
          {chatbot.badgeInvitationTexte}
        </div>
      )}

      <div
        id="louise-panel"
        data-chat-panel
        role="dialog"
        aria-modal="false"
        aria-labelledby="louise-panel-title"
        hidden
        class="chat-panel fixed bottom-24 right-6 z-40 flex w-[calc(100vw-3rem)] max-w-sm flex-col overflow-hidden rounded-card border border-surface-2 bg-surface"
      >
        <header class="flex items-center justify-between gap-3 border-b border-surface-2 px-5 py-4">
          <div class="flex items-center gap-3">
            <span class="grid h-9 w-9 shrink-0 place-items-center" aria-hidden="true">
              <svg viewBox="0 0 100 100" class="h-full w-full">
                <polygon
                  points="50,4 91,27 91,73 50,96 9,73 9,27"
                  fill="var(--surface-2)"
                  stroke="var(--accent)"
                  stroke-width="5"
                />
                <text
                  x="50"
                  y="66"
                  font-family="var(--font-display)"
                  font-weight="700"
                  font-size="42"
                  fill="var(--accent)"
                  text-anchor="middle">L</text
                >
              </svg>
            </span>
            <div>
              <p id="louise-panel-title" class="font-display text-sm font-bold text-text">Louise · Guide du site</p>
              <p class="font-mono text-[0.65rem] uppercase tracking-[0.1em] text-text-muted">{chatbot.mentionIA}</p>
            </div>
          </div>
          <button
            type="button"
            data-chat-close
            aria-label="Fermer la discussion"
            class="grid h-8 w-8 shrink-0 place-items-center rounded-full text-text-muted transition-colors hover:text-text"
          >
            <Icon name="x" size={16} />
          </button>
        </header>

        <div data-chat-messages class="chat-messages flex-1 space-y-3 overflow-y-auto px-5 py-4" aria-live="polite" />

        <div data-chat-suggestions class="flex flex-wrap gap-2 px-5 pb-3">
          {chatbot.questionsSuggerees.map((question) => (
            <button
              type="button"
              data-chat-suggestion
              class="rounded-pill border border-surface-2 px-3 py-1.5 text-left font-mono text-xs text-text-muted transition-colors hover:border-accent/40 hover:text-text"
            >
              {question}
            </button>
          ))}
        </div>

        <form data-chat-form class="flex items-center gap-2 border-t border-surface-2 px-4 py-3">
          <label for="louise-input" class="sr-only">Votre message</label>
          <input
            id="louise-input"
            data-chat-input
            type="text"
            maxlength="500"
            autocomplete="off"
            placeholder="Posez votre question…"
            required
            class="form-field w-full rounded-pill border border-surface-2 bg-bg px-4 py-2.5 text-sm text-text outline-none transition-colors duration-300 focus:border-accent"
          />
          <button
            type="submit"
            data-chat-send
            aria-label="Envoyer"
            class="grid h-10 w-10 shrink-0 place-items-center rounded-full bg-accent text-bg transition-transform duration-300 hover:scale-105 disabled:opacity-50"
          >
            <Icon name="send" size={16} />
          </button>
        </form>
      </div>
    </div>
  )
}

<style>
  /* Bulle : apparaît 1,5 s après le chargement (chat-bubble-enter), puis le
     battement de cœur (chat-heartbeat) reste déclaré mais mis en pause dès
     le départ (animation-play-state) — scripts/motion.ts (initChatAttention)
     est seul à le faire « running » par salves, jamais la CSS seule. */
  .chat-bubble {
    clip-path: polygon(25% 0%, 75% 0%, 100% 50%, 75% 100%, 25% 100%, 0% 50%);
    background: var(--accent);
    box-shadow: var(--glow);
    opacity: 0;
    transform: scale(0.4);
    pointer-events: none;
    will-change: transform;
    animation:
      chat-bubble-enter 0.5s cubic-bezier(0.34, 1.56, 0.64, 1) 1.5s 1 forwards,
      chat-heartbeat 1.3s ease-in-out infinite;
    animation-play-state: running, paused;
  }
  .chat-bubble:hover {
    animation-play-state: running, paused !important;
    transform: scale(1.05) !important;
    box-shadow: var(--glow-strong) !important;
  }
  @keyframes chat-bubble-enter {
    to {
      opacity: 1;
      transform: scale(1);
      pointer-events: auto;
    }
  }
  /* Rythme « lub-dub » (~55 bpm) : deux pulsations rapprochées puis un temps
     de repos jusqu'à la fin du cycle — le battement/repos par salves de 3
     (3 cycles puis 8 s de pause) est géré en JS via animation-play-state. */
  @keyframes chat-heartbeat {
    0%, 100% {
      transform: scale(1);
      box-shadow: var(--glow);
    }
    14% {
      transform: scale(1.12);
      box-shadow: var(--glow-strong);
    }
    28% {
      transform: scale(1);
      box-shadow: var(--glow);
    }
    42% {
      transform: scale(1.14);
      box-shadow: var(--glow-strong);
    }
    70% {
      transform: scale(1);
      box-shadow: var(--glow);
    }
  }

  /* Onde radar : une seule pulsation par salve de battements, déclenchée en
     JS (classe .is-pinging ajoutée puis retirée à chaque salve). */
  .chat-radar {
    clip-path: polygon(25% 0%, 75% 0%, 100% 50%, 75% 100%, 25% 100%, 0% 50%);
    border: 2px solid var(--accent);
    opacity: 0;
    pointer-events: none;
  }
  .chat-radar.is-pinging {
    animation: chat-radar-ping 1s ease-out 1;
  }
  @keyframes chat-radar-ping {
    from {
      transform: scale(1);
      opacity: 0.5;
    }
    to {
      transform: scale(1.8);
      opacity: 0;
    }
  }

  /* Badge d'invitation : indépendant du réglage d'animation ci-dessus. */
  .chat-badge {
    opacity: 0;
    transform: translateY(8px);
    transition: opacity 0.3s ease, transform 0.3s ease;
    pointer-events: none;
  }
  .chat-badge.is-visible {
    opacity: 1;
    transform: none;
  }

  .chat-panel {
    max-height: min(30rem, calc(100vh - 8rem));
    opacity: 0;
    transform: translateY(12px) scale(0.98);
    transition: opacity 0.25s ease, transform 0.25s ease;
  }
  .chat-panel.is-open {
    opacity: 1;
    transform: none;
  }
  .chat-messages {
    scrollbar-width: thin;
  }
  @media (max-width: 380px) {
    .chat-panel {
      right: 1rem;
      bottom: 5.5rem;
    }
    .chat-bubble,
    .chat-radar,
    .chat-badge {
      right: 1rem;
    }
    /* Empreinte réduite : sur petit écran, le badge reste une pastille
       compacte collée à la bulle plutôt qu'un large bandeau qui recouvrirait
       davantage le contenu de la page en dessous. */
    .chat-badge {
      max-width: 10rem;
      padding: 0.5rem 0.75rem;
      font-size: 0.75rem;
    }
  }

  /* La bulle reste statique, visible immédiatement, glow fixe — jamais de
     battement ni d'onde radar. Le badge n'est pas concerné : c'est un texte
     informatif, pas un mouvement, et sa propre transition est déjà neutralisée
     par la règle globale prefers-reduced-motion (src/styles/global.css). */
  @media (prefers-reduced-motion: reduce) {
    .chat-bubble {
      opacity: 1;
      transform: none;
      animation: none;
      box-shadow: var(--glow);
      pointer-events: auto;
    }
    .chat-radar {
      display: none;
    }
  }
</style>
