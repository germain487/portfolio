---
import { getEntry } from 'astro:content';
import Icon from './Icon.astro';

const settingsEntry = await getEntry('settings', 'settings');
const footerEntry = await getEntry('footer', 'footer');
const settings = settingsEntry!.data;
const footer = footerEntry!.data;

const links = [
  { label: 'Accueil', href: '/' },
  { label: 'À propos', href: '/a-propos' },
  { label: 'Projets', href: '/projets' },
  { label: 'Services', href: '/services' },
  { label: 'Contact', href: '/contact' },
];

const socialIconMap: Record<string, string> = {
  LinkedIn: 'linkedin',
  GitHub: 'github',
  X: 'twitter',
  Facebook: 'facebook',
};

const year = new Date().getFullYear();
---

<footer class="relative overflow-hidden border-t border-surface-2" transition:persist>
  {footer.filigraneNimba && (
    <svg
      class="pointer-events-none absolute inset-x-0 bottom-0 h-40 w-full opacity-[0.08]"
      viewBox="0 0 1200 200"
      preserveAspectRatio="none"
      aria-hidden="true"
    >
      <path
        d="M0 200 L140 90 L230 150 L340 40 L430 130 L520 70 L620 160 L720 60 L830 140 L930 20 L1040 120 L1130 80 L1200 150 L1200 200 Z"
        fill="none"
        stroke="var(--accent)"
        stroke-width="2"
      />
    </svg>
  )}

  <div class="relative mx-auto max-w-6xl px-6 py-16">
    <div class="flex flex-col items-center gap-8 text-center md:flex-row md:items-center md:justify-between md:text-left">
      <a href="/" class="flex items-center gap-2 font-display text-lg font-bold text-text">
        <svg width="26" height="26" viewBox="0 0 100 100" fill="none" aria-hidden="true">
          <polygon points="50,4 91,27 91,73 50,96 9,73 9,27" fill="none" stroke="var(--accent)" stroke-width="6" />
          <text x="50" y="66" font-family="var(--font-display)" font-weight="700" font-size="46" fill="var(--accent)" text-anchor="middle">G</text>
        </svg>
        {settings.wordmark}
      </a>

      <nav class="flex flex-wrap items-center justify-center gap-x-6 gap-y-2" aria-label="Navigation du pied de page">
        {links.map((link) => (
          <a href={link.href} class="font-mono text-xs uppercase tracking-[0.1em] text-text-muted transition-colors hover:text-accent">
            {link.label}
          </a>
        ))}
      </nav>

      <div class="flex items-center gap-3">
        {settings.reseaux.map((reseau) => (
          <a
            href={reseau.url}
            target="_blank"
            rel="noopener noreferrer"
            aria-label={reseau.plateforme}
            class="grid h-9 w-9 place-items-center rounded-full border border-surface-2 text-text-muted transition-all duration-300 hover:border-accent hover:text-accent"
          >
            <Icon name={socialIconMap[reseau.plateforme] ?? 'globe'} size={15} />
          </a>
        ))}
      </div>
    </div>

    <div class="mt-10 border-t border-surface-2 pt-8 text-center font-mono text-xs text-text-muted md:text-left">
      {footer.mention} · {year}
    </div>
  </div>
</footer>
