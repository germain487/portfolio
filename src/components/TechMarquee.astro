---
interface Props {
  technologies: string[];
}

const { technologies } = Astro.props;
const items = [...technologies, ...technologies];
---

<div class="marquee-wrap overflow-hidden border-y border-surface-2 py-6">
  <div class="marquee-track flex w-max items-center gap-8">
    {items.map((tech) => (
      <>
        <span class="font-mono text-sm uppercase tracking-[0.08em] text-text-muted">{tech}</span>
        <svg width="10" height="10" viewBox="0 0 100 100" aria-hidden="true" class="shrink-0">
          <polygon points="50,4 91,27 91,73 50,96 9,73 9,27" fill="var(--accent-soft)" opacity="0.6" />
        </svg>
      </>
    ))}
  </div>
</div>

<style>
  .marquee-wrap:hover .marquee-track {
    animation-play-state: paused;
  }
  .marquee-track {
    animation: marquee 32s linear infinite;
  }
  @keyframes marquee {
    from {
      transform: translateX(0);
    }
    to {
      transform: translateX(-50%);
    }
  }
</style>
