<div data-preloader class="fixed inset-0 z-[100] grid place-items-center bg-bg" aria-hidden="true">
  <svg width="72" height="72" viewBox="0 0 100 100" fill="none">
    <polygon
      points="50,4 91,27 91,73 50,96 9,73 9,27"
      fill="none"
      stroke="var(--surface-2)"
      stroke-width="3"
    />
    <polygon
      data-preloader-hex
      points="50,4 91,27 91,73 50,96 9,73 9,27"
      fill="none"
      stroke="var(--accent)"
      stroke-width="3"
      stroke-linecap="round"
    />
    <text
      x="50"
      y="66"
      font-family="var(--font-display)"
      font-weight="700"
      font-size="40"
      fill="var(--text)"
      text-anchor="middle">G</text
    >
  </svg>
</div>
<script is:inline>
  if (sessionStorage.getItem('portfolio-preloader-shown') === '1') {
    document.currentScript.previousElementSibling.style.display = 'none';
  } else {
    document.documentElement.classList.add('overflow-hidden');
  }
</script>
